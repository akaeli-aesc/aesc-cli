# docker-compose automatically loads this file

# Your user/group IDs (detected automatically)
# Run ./setup.sh to auto-populate these values
UID=1000
GID=1000

# LLM Configuration - ADD YOUR API KEY HERE
# ash auto-detects provider from API key and selects default model
# You can override the model with AESC_MODEL_NAME

# Option 1: Anthropic Claude (recommended)
# Just add your API key - model is auto-selected
# ANTHROPIC_API_KEY=sk-ant-api03-your-key-here
# Auto-selects: claude-sonnet-4-20250514 (latest Claude Sonnet 4.5)
#
# Or override model:
# AESC_MODEL_NAME=claude-sonnet-4-20250514  # Claude Sonnet 4.5 (latest, recommended)
# AESC_MODEL_NAME=claude-haiku-4-20250514   # Claude Haiku 4.5 (fast, efficient)

# Option 2: OpenAI
# Just add your API key - model is auto-selected
# OPENAI_API_KEY=sk-your-key-here
# Auto-selects: gpt-4o
#
# Or override model:
# AESC_MODEL_NAME=gpt-4o          # GPT-4o (latest)
# AESC_MODEL_NAME=gpt-4-turbo     # GPT-4 Turbo

# Option 3: Local Ollama (free, no API key needed)
# OLLAMA_BASE_URL=http://host.docker.internal:11434/v1
# AESC_MODEL_NAME=llama3
